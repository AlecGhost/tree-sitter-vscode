{
  "name": "tree-sitter-vscode",
  "displayName": "tree-sitter-vscode",
  "description": "Tree-sitter integration into VSCode",
  "author": {
    "name": "AlecGhost",
    "url": "https://github.com/AlecGhost"
  },
  "publisher": "AlecGhost",
  "version": "0.4.0",
  "license": "Apache-2.0",
  "repository": {
    "url": "https://github.com/AlecGhost/tree-sitter-vscode"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": [
      {
        "title": "tree-sitter-vscode config",
        "properties": {
          "tree-sitter-vscode.languageConfigs": {
            "description": "A list of objects with the keys \"lang\", \"parser\", and \"highlights\". Optionally \"injections\", \"injectionOnly\", \"folds\", and \"semanticTokenTypeMappings\" can be added.",
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "lang",
                "parser",
                "highlights"
              ],
              "properties": {
                "lang": {
                  "type": "string",
                  "description": "The name of the language"
                },
                "parser": {
                  "type": "string",
                  "description": "The path to the parser `.wasm` file"
                },
                "highlights": {
                  "type": "string",
                  "description": "The path to the highlights `.scm` file"
                },
                "injections": {
                  "type": [
                    "string",
                    null
                  ],
                  "description": "The path to the injections `.scm` file"
                },
                "folds": {
                  "type": [
                    "string",
                    null
                  ],
                  "description": "The path to the folds `.scm` file"
                },
                "injectionOnly": {
                  "type": "boolean",
                  "default": false,
                  "description": "Use language only for injections, not for top-level syntax highlighting"
                },
                "semanticTokenTypeMappings": {
                  "type": "object",
                  "description": "Mappings from highlighting query names to VSCode token types and modifiers",
                  "additionalProperties": {
                    "type": "object",
                    "properties": {
                      "targetTokenModifiers": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "targetTokenType": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "targetTokenType"
                    ]
                  }
                }
              }
            },
            "default": []
          },
          "tree-sitter-vscode.debug": {
            "type": "boolean",
            "default": false,
            "description": "Enable debug logging"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "tree-sitter-vscode.reload",
        "title": "tree-sitter-vscode: Reload"
      }
    ]
  },
  "scripts": {
    "lint:check": "eslint src/ --ext ts",
    "lint:fix": "eslint src/ --ext ts --fix",
    "format:check": "prettier src/ --check",
    "format:fix": "prettier src/ --write",
    "clean": "rm -rf node_modules && rm -rf dist",
    "prebuild": "rm -rf dist && mkdir dist && cp node_modules/web-tree-sitter/web-tree-sitter.wasm dist/",
    "build": "tsc --noEmit && webpack && npm run format:check && npm run lint:check",
    "watch": "webpack --watch",
    "pretest": "npm run build",
    "test": "vscode-test",
    "package": "webpack --mode production --devtool hidden-source-map",
    "vscode:prepublish": "npm run build && npm run package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "25.x",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "3.7.4",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@vscode/vsce": "^3.7.1",
    "web-tree-sitter": "^0.26.6"
  }
}